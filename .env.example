# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_PASSWORD=change-me-in-production

# Database
DATABASE_URL=postgresql://apto:apto@localhost:5432/apto

# Stripe — Modo activo (test o live)
STRIPE_MODE=test

# Stripe Live
STRIPE_LIVE_SECRET_KEY=sk_live_...
STRIPE_LIVE_WEBHOOK_SECRET=whsec_...
STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_...

# Stripe Test
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_TEST_WEBHOOK_SECRET=whsec_...
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_...
STRIPE_TEST_PRICE_STUDENT=price_...
STRIPE_TEST_PRICE_PROFESSIONAL=price_...
STRIPE_LIVE_PRICE_STUDENT=price_...
STRIPE_LIVE_PRICE_PROFESSIONAL=price_...

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=APTO <noreply@apto.org.mx>

# Gemini (Newsletter IA)
GEMINI_API_KEY=AIza...

# Cloudflare R2 (Storage)
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=apto-files
R2_ACCOUNT_ID=...
R2_PUBLIC_URL=https://files.apto.org.mx

# Certificados (verificación)
CERTIFICATE_SECRET=generate-a-random-256bit-hex-secret

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Cron Jobs
CRON_SECRET="your-cron-secret-here"
